# Notion CMS — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter le fichier .env

# Clé d'intégration Notion (commence par secret_...)
# Obtenir sur : https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la base Notion "Projets Portfolio"
# Trouver dans l'URL Notion : notion.so/.../[CET-ID]?v=...
NOTION_PROJECTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
